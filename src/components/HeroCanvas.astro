---
// WebGL hero background — the actual scene, built in Unicorn Studio's
// no-code editor (https://unicorn.studio), not a hand-rolled shader.
// Embedded via Unicorn Studio's runtime SDK per their embed guide:
// https://www.unicorn.studio/docs/embed/
//
// Desktop-only. Mobile gets a lightweight canvas "dot grid" instead (below)
// — the WebGL scene never fully solved mobile (tall/narrow crop reveals
// busy image content the copy can't sit on legibly, see the .hero-scrim
// history in index.astro), and loading a full WebGL runtime + texture on a
// phone is real weight for a background that has to fight the copy for
// attention anyway. Below 768px this component skips the Unicorn Studio SDK
// entirely rather than loading it and hiding the result.
//
// Fades in over .hero's flat placeholder-gray fill (see index.astro) once
// ready, instead of popping in. Wired to Lenis smooth-scroll via
// UnicornStudio.setScroll() (see the lenis.on('scroll', …) call in
// Base.astro), so scroll-driven motion in the scene stays in sync with the
// site's virtual scroll instead of drifting from native window.scrollY.
// cacheBust: Unicorn Studio's CDN can take 1-2 min to pick up edits published
// in the editor (see "Caching Behavior" in their embed guide), and browsers
// cache the project JSON on top of that. Bump this string whenever a scene
// edit isn't showing up live to force a fresh fetch.
const { projectId = 'XRccr6ECgdKFWpApifBr', cacheBust = '1' } = Astro.props;
---
<div
  id="hero-unicorn"
  class="hero-unicorn"
  data-us-project={`${projectId}?update=${cacheBust}`}
  data-us-scale="1"
  data-us-dpi="1.5"
  data-us-lazyload="true"
  data-us-production="true"
  data-us-alttext="Decorative animated background"
  data-us-arialabel="Decorative animated background"
></div>

<canvas id="hero-dotgrid" class="hero-dotgrid" aria-hidden="true"></canvas>

<style>
  /* Fills the hero panel exactly. (Previously oversized to 125% height to
     force a top-crop, but the scene appears to fit-to-contain within
     whatever box it's given rather than cover-crop it — the taller,
     more-portrait box was shrinking the scene down and leaving empty
     margins on the left/right. Matching the container 1:1 avoids that.) */
  .hero-unicorn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    /* Starts invisible over .hero's flat placeholder gray (see index.astro),
       fades in once the scene has actually initialized — avoids a jarring
       pop-in while the SDK/scene assets load, and hides the initial unstyled
       flash on slow connections. Slow/long on purpose: the scene is a big
       texture and briefly glitches (a line across the upper half) on its
       first few rendered frames, so the fade needs enough time — combined
       with the READY_DELAY_MS buffer below — to fully cover it rather than
       reveal it mid-glitch. */
    opacity: 0;
    transition: opacity 1.3s ease;
  }
  .hero-unicorn.is-ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-unicorn {
      transition: none;
    }
  }

  /* Mobile fallback: a light-gray field with a subtle animated dot grid
     (perlin noise driving each dot's darkness) instead of the WebGL scene —
     see the component comment above. Drawn immediately (no fade needed,
     nothing to glitch) and swapped in purely by CSS breakpoint so there's
     no flash of the wrong background before JS runs. */
  .hero-dotgrid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: none;
    background: var(--bg-soft);
  }
  @media (max-width: 768px) {
    .hero-unicorn { display: none; }
    .hero-dotgrid { display: block; }
  }
</style>

<script is:inline>
  // astro:page-load (not a plain top-level IIFE) so this reruns on every
  // view-transition navigation back to the homepage, not just the very
  // first load — inline scripts don't auto-rerun under Astro's transitions.
  document.addEventListener('astro:page-load', function () {
    var unicornEl = document.getElementById('hero-unicorn');
    var gridEl = document.getElementById('hero-dotgrid');
    if (!unicornEl && !gridEl) return; // not on this page

    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Checked once per page-load, same as the reduced-motion check below —
    // this isn't meant to react live to a mid-session resize/rotation, just
    // to pick the right background for the device this page loaded on.
    var isMobile = window.matchMedia('(max-width: 768px)').matches;

    if (isMobile) {
      // Never touch the Unicorn Studio SDK on mobile — don't load it, don't
      // init it, don't pay for the texture download.
      if (unicornEl) unicornEl.removeAttribute('data-us-project');
      if (gridEl) startDotGrid(gridEl, reduce);
      return;
    }

    if (!unicornEl) return;

    // Skip the scene under reduced motion — hero falls back to the plain
    // placeholder-gray background from .hero. Must run before
    // UnicornStudio.init() picks up the data-us-project attribute below.
    if (reduce) {
      unicornEl.removeAttribute('data-us-project');
      return;
    }

    // init() resolving means the scene has mounted, but it still takes a
    // few frames to actually settle (the glitch line mentioned above) —
    // hold the fade-in behind this extra buffer so it's never visibly
    // revealed mid-glitch.
    var READY_DELAY_MS = 400;
    function ready() {
      setTimeout(function () { unicornEl.classList.add('is-ready'); }, READY_DELAY_MS);
    }

    // Unicorn Studio's standard SDK loader snippet (embed guide, "Native"
    // path): load the runtime once, then init any data-us-project elements.
    // init() returns a promise that resolves once the scene is actually
    // ready — that's what triggers the fade-in. onerror/catch still fade
    // in (to the flat placeholder) so a failed load doesn't stay stuck gray.
    var u = window.UnicornStudio;
    if (u && u.init) {
      Promise.resolve(u.init()).then(ready).catch(ready);
    } else {
      window.UnicornStudio = { isInitialized: false };
      var i = document.createElement('script');
      i.src = 'https://cdn.jsdelivr.net/gh/hiunicornstudio/unicornstudio.js@v2.2.6/dist/unicornStudio.umd.js';
      i.onload = function () {
        Promise.resolve(window.UnicornStudio.init()).then(ready).catch(ready);
      };
      i.onerror = ready;
      (document.head || document.body).appendChild(i);
    }

    // Tear down the WebGL context before this page's content is swapped
    // out by a view transition, so navigating away doesn't leave a live
    // scene running in the background.
    document.addEventListener('astro:before-swap', function cleanup() {
      if (window.UnicornStudio && typeof window.UnicornStudio.destroy === 'function') {
        window.UnicornStudio.destroy();
      }
      document.removeEventListener('astro:before-swap', cleanup);
    }, { once: true });
  });

  // Minimal seeded 2D Perlin noise — classic lattice-gradient noise with a
  // fixed permutation table (no external dependency; this is the whole
  // reason it's hand-rolled rather than an npm package for a handful of
  // background dots). Returns smooth, continuous values roughly in -1..1.
  function makeNoise2D(seed) {
    var p = new Uint8Array(256);
    var perm = new Uint8Array(512);
    var s = seed >>> 0 || 1;
    function rand() {
      s = (s * 1664525 + 1013904223) >>> 0;
      return s / 4294967296;
    }
    for (var i = 0; i < 256; i++) p[i] = i;
    for (var i = 255; i > 0; i--) {
      var j = Math.floor(rand() * (i + 1));
      var t = p[i]; p[i] = p[j]; p[j] = t;
    }
    for (var i = 0; i < 512; i++) perm[i] = p[i & 255];

    function fade(t) { return t * t * t * (t * (t * 6 - 15) + 10); }
    function lerp(a, b, t) { return a + t * (b - a); }
    function grad(hash, x, y) {
      var h = hash & 7;
      var u = h < 4 ? x : y;
      var v = h < 4 ? y : x;
      return ((h & 1) ? -u : u) + ((h & 2) ? -2 * v : 2 * v);
    }

    return function noise2D(x, y) {
      var X = Math.floor(x) & 255, Y = Math.floor(y) & 255;
      var xf = x - Math.floor(x), yf = y - Math.floor(y);
      var u = fade(xf), v = fade(yf);
      var aa = perm[X + perm[Y]], ab = perm[X + perm[Y + 1]];
      var ba = perm[X + 1 + perm[Y]], bb = perm[X + 1 + perm[Y + 1]];
      return lerp(
        lerp(grad(aa, xf, yf), grad(ba, xf - 1, yf), u),
        lerp(grad(ab, xf, yf - 1), grad(bb, xf - 1, yf - 1), u),
        v
      );
    };
  }

  function startDotGrid(canvas, reduce) {
    var ctx = canvas.getContext('2d');
    if (!ctx) return;
    var noise = makeNoise2D(1337);
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var spacing = 16; // px between dots
    var w = 0, h = 0, cols = 0, rows = 0, raf = null;

    function resize() {
      var rect = canvas.getBoundingClientRect();
      w = rect.width; h = rect.height;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(w / spacing) + 1;
      rows = Math.ceil(h / spacing) + 1;
      draw(lastT);
    }

    var lastT = 0;
    function draw(t) {
      lastT = t;
      ctx.clearRect(0, 0, w, h);
      var time = t * 0.0006; // organic drift — was 0.00012, felt frozen
      for (var yi = 0; yi < rows; yi++) {
        for (var xi = 0; xi < cols; xi++) {
          // Spatial frequency scaled to the tighter spacing so the noise
          // "blobs" stay about the same real-world size as before.
          var n = noise(xi * 0.11 + time, yi * 0.11 + time * 0.7); // -1..1
          var a = (n + 1) / 2; // 0..1
          a = Math.pow(a, 3); // most dots stay faint; only a few "activate"
          var alpha = 0.035 + a * 0.09; // very faint — barely darker than bg
          var r = 0.55 + a * 0.45; // small dots
          ctx.beginPath();
          ctx.fillStyle = 'rgba(35, 31, 32, ' + alpha.toFixed(3) + ')';
          ctx.arc(xi * spacing, yi * spacing, r, 0, Math.PI * 2);
          ctx.fill();
        }
      }
    }

    function frame(t) {
      draw(t);
      raf = requestAnimationFrame(frame);
    }

    resize();
    window.addEventListener('resize', resize);
    if (!reduce) raf = requestAnimationFrame(frame);

    document.addEventListener('astro:before-swap', function cleanup() {
      if (raf) cancelAnimationFrame(raf);
      window.removeEventListener('resize', resize);
      document.removeEventListener('astro:before-swap', cleanup);
    }, { once: true });
  }
</script>
