---
import Base from '../layouts/Base.astro';
import { company, formEndpoint } from '../data/site.js';
---
<Base title="Contact" description="Contact Eagle Restorations for historic restoration, seismic retrofit, and adobe reconstruction projects in California.">
  <section class="page-head">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="muted">Have a question or a project in mind? We'd love to hear from you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="info-item">
          <h3>Office</h3>
          <p>5441 Cogswell Rd, Suite A<br />Arcadia, CA 91006</p>
        </div>
        <div class="info-item">
          <h3>Email</h3>
          <p><a href={`mailto:${company.email}`}>{company.email}</a></p>
        </div>
        <div class="info-item">
          <h3>Phone</h3>
          <p><a href={`tel:${company.phoneHref}`}>{company.phone}</a></p>
        </div>
        <div class="info-item">
          <h3>Office Hours</h3>
          <p>{company.hours}</p>
        </div>
      </div>

      <form
        class="contact-form"
        id="contactForm"
        name="contact"
        method="POST"
        action={formEndpoint || undefined}
        data-endpoint={formEndpoint}
        data-mailto={company.email}
      >
        <p class="form-note">Have a question? Send us a message.</p>
        <div class="row">
          <label>Name<input type="text" name="name" required /></label>
          <label>Email<input type="email" name="email" required /></label>
        </div>
        <label>Phone<input type="tel" name="phone" /></label>
        <label>Message<textarea name="message" rows="6" required></textarea></label>
        <!-- honeypot: bots fill this, humans don't -->
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
        <button type="submit" class="btn">Send Message</button>
        <p class="form-status" id="formStatus" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Base>

<style>
  .page-head { background: var(--bg-light); padding: 70px 0; }
  .page-head h1 { font-size: clamp(2.4rem, 5vw, 3.6rem); margin-bottom: 8px; }

  .contact-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 56px; }
  .info-item { margin-bottom: 28px; }
  .info-item h3 {
    font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--brand-dark); margin-bottom: 6px;
  }
  .info-item p { font-size: 1.1rem; margin: 0; }

  .contact-form { background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--radius); padding: 34px; }
  .form-note { font-family: var(--font-head); font-weight: 600; font-size: 1.15rem; margin-bottom: 20px; }
  .contact-form label {
    display: block; margin-bottom: 16px;
    font-family: var(--font-head); font-size: 0.82rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-soft);
  }
  .contact-form input, .contact-form textarea {
    display: block; width: 100%; margin-top: 6px;
    font-family: var(--font-body); font-size: 1rem;
    padding: 12px 14px; border: 1px solid var(--line); border-radius: var(--radius);
    background: #fff; color: var(--ink);
  }
  .contact-form input:focus, .contact-form textarea:focus { outline: 2px solid var(--gold); border-color: var(--gold); }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .contact-form .btn { border: 0; cursor: pointer; margin-top: 6px; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .form-status { margin: 14px 0 0; font-size: 0.95rem; min-height: 1.2em; }
  .form-status.ok { color: #2e7d32; }
  .form-status.err { color: #c0392b; }

  @media (max-width: 760px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    .row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contactForm');
  const status = document.getElementById('formStatus');
  form?.addEventListener('submit', async (e) => {
    if (form.querySelector('[name="_gotcha"]')?.value) { e.preventDefault(); return; }
    const endpoint = form.dataset.endpoint;
    const data = new FormData(form);
    if (!endpoint) {
      // No backend configured yet — fall back to opening the visitor's email client.
      e.preventDefault();
      const to = form.dataset.mailto;
      const subject = encodeURIComponent(`Website enquiry from ${data.get('name') || ''}`);
      const body = encodeURIComponent(
        `Name: ${data.get('name') || ''}\nEmail: ${data.get('email') || ''}\nPhone: ${data.get('phone') || ''}\n\n${data.get('message') || ''}`
      );
      window.location.href = `mailto:${to}?subject=${subject}&body=${body}`;
      return;
    }
    e.preventDefault();
    status.textContent = 'Sending…';
    status.className = 'form-status';
    try {
      const res = await fetch(endpoint, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) {
        form.reset();
        status.textContent = 'Thanks — your message has been sent. We\'ll be in touch soon.';
        status.className = 'form-status ok';
      } else {
        throw new Error('bad response');
      }
    } catch (err) {
      status.textContent = 'Something went wrong. Please email us directly at ' + form.dataset.mailto + '.';
      status.className = 'form-status err';
    }
  });
</script>
