---
import { nav, announcement, company } from '../data/site.js';
const path = Astro.url.pathname;
---
<div class="announce">
  <a href={announcement.href}>{announcement.text} &rarr;</a>
</div>

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={company.name}>
      <img src="/eagle-restorations-logo.svg" alt={company.name} class="brand-logo" width="552" height="158" />
    </a>

    <nav class="main-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          data-label={item.label}
          class={path.startsWith(item.href) && item.href !== '/' ? 'active' : ''}
        ><span class="nav-label">{item.label}</span></a>
      ))}
    </nav>

    <a href="/contact/" class="btn quote-btn">Plan Your Restoration</a>

    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/altadena-fire/">Rebuilding Altadena</a>
    <a href="/contact/" class="btn">Plan Your Restoration</a>
  </div>
</header>

<style>
  .announce {
    background: #3c3429;
    color: #fff;
    text-align: center;
    font-size: 0.92rem;
    padding: 9px 16px;
  }
  .announce a { color: #fff; }
  .announce a:hover { color: var(--gold); text-decoration: none; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    min-height: 86px;
  }
  .brand { display: flex; align-items: center; }
  .brand:hover { text-decoration: none; }
  .brand-logo { height: 46px; width: auto; display: block; }
  /* -5% vs. the previous 67.45px/55.55px. Height-only scaling (width
     stays auto) keeps the logo's left edge flush with the container padding,
     since the flex item just grows to the right. */
  @media (max-width: 940px) { .brand-logo { height: 64.08px; } }
  @media (max-width: 480px) { .brand-logo { height: 52.77px; } }

  .main-nav {
    margin-left: auto;
    display: flex;
    gap: 30px;
  }
  .main-nav a {
    display: inline-grid;
    font-family: var(--font-head);
    font-weight: 500;
    color: var(--ink);
    font-size: 0.9rem;
  }
  .main-nav a .nav-label { grid-area: 1 / 1; }
  /* hidden bold ghost reserves width so hover-bolding doesn't shift siblings */
  .main-nav a::after {
    content: attr(data-label);
    grid-area: 1 / 1;
    font-weight: 700;
    visibility: hidden;
  }
  .main-nav a:hover { color: var(--gold-dark); text-decoration: none; }
  .main-nav a.active { color: var(--gold-dark); text-decoration: none; }
  .main-nav a:hover .nav-label,
  .main-nav a.active .nav-label { font-weight: 700; }

  .quote-btn { flex: none; }

  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    width: 46px;
    height: 46px;
    background: var(--brand-dark);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
    margin-left: auto;
    flex: none;
    transition: opacity 0.15s ease;
  }
  .nav-toggle:hover { opacity: 0.85; }
  .nav-toggle span {
    width: 20px; height: 2px; border-radius: 2px; background: #fff; display: block;
    transition: transform 0.28s ease, opacity 0.2s ease;
  }
  /* Morph the 3 bars into an X: top/bottom bars slide toward the middle bar's
     position (translateY covers the gap + the bar itself) and rotate into an
     X; the middle bar just fades out rather than rotating, which reads
     cleaner than a 4-line X. transform-origin stays centered (the default)
     so both bars rotate in place once translated. */
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 12px 24px 22px;
    border-top: 1px solid var(--line);
  }
  .mobile-nav a {
    font-family: var(--font-head);
    color: var(--ink);
    padding: 10px 0;
    font-size: 1.05rem;
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav .btn {
    width: max-content;
    margin-top: 8px;
    /* Reset .mobile-nav a overrides so .btn base styles apply correctly */
    padding: 15px 30px;
    font-size: 0.8rem;
    color: var(--brand-dark);
  }

  @media (max-width: 940px) {
    .main-nav, .quote-btn { display: none; }
    .nav-toggle { display: flex; }
    .announce { display: none; }
  }
</style>

<script>
  // astro:page-load (not a plain top-level run) so this re-attaches on every
  // view-transition navigation, not just the very first page load — the
  // header's DOM (including #navToggle/#mobileNav) is swapped for fresh
  // nodes on each transition, which silently drops the click listener
  // attached to the old button. Without this, the toggle only ever works
  // immediately after a hard refresh.
  document.addEventListener('astro:page-load', function () {
    const t = document.getElementById('navToggle');
    const m = document.getElementById('mobileNav');
    t?.addEventListener('click', () => {
      const isOpen = m?.classList.toggle('open');
      t.classList.toggle('open', isOpen);
      t.setAttribute('aria-expanded', String(!!isOpen));
    });
  });
</script>
