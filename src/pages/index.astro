---
import Base from '../layouts/Base.astro';
import HeroCanvas from '../components/HeroCanvas.astro';
import { company, stats, localImage } from '../data/site.js';
import portfolio from '../data/portfolio.json';

const services = [
  {
    title: 'Historic Restoration',
    items: [
      'Commercial buildings, churches, and federal, state, and local landmarks',
      'Materials restoration: stained glass, fine carpentry, stone and marble, light fixtures, statues and mouldings',
      'Door and window fabrication and repair',
    ],
  },
  {
    title: 'Seismic & Structural Retrofit',
    items: [
      'Structural support and bracing',
      'Interior demo and retrofit',
      'Foundation bolting',
    ],
  },
  {
    title: 'Adobe Restoration & Reconstruction',
    items: [
      'Adobe mud plastering',
      'Adobe block repairs and recreation',
      'Adobe retrofitting',
      'Period-authentic interior lime plastering',
    ],
  },
  {
    title: 'Building Materials Restoration',
    items: [
      'Stained glass, fine carpentry, stone and marble, light fixtures, statues and mouldings',
      'Repairs to brick, historic concrete, tile, and plaster',
      'Door and window fabrication and repair',
    ],
  },
];

const featuredSlugs = ['leo-carillo-ranch', 'bank-italy', 'spreckles-organ', 'rancho-los-cerritos'];
const featured = featuredSlugs
  .map((s) => portfolio.find((p) => p.slug === s))
  .filter(Boolean);
const aboutImg = portfolio.find((p) => p.slug === 'mission-san-miguel')?.image
  ?? featured[0]?.image;

// Every project image across the site, for the about-section slideshow
const slideshowImages = [...new Set(
  portfolio.filter((p) => p.image).map((p) => localImage(p.image))
)];
const firstSlide = localImage(aboutImg) || slideshowImages[0];
---
<Base>
  <!-- Hero -->
  <section class="hero">
    <HeroCanvas />
    <div class="hero-content container">
      <p class="hero-kicker">
        Class&nbsp;'B' Licensed General Contractor
        <span class="lic">{company.license} &middot; Bonded &amp; Insured</span>
      </p>
      <h1>Southern California's Premier Historical &amp; Structural Specialists</h1>
      <p class="hero-sub">
        For more than three decades, restoring California's landmarks to the
        Secretary of the Interior's Standards for the Treatment of Historic Properties.
      </p>
      <div class="hero-cta">
        <a href="/contact/" class="btn">Plan Your Restoration</a>
        <a href="/projects/" class="btn btn-outline">View Our Work</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container about-grid">
      <div class="about-media">
        <div class="slideshow" id="aboutSlideshow" role="img"
             aria-label="A rotating gallery of Eagle Restorations projects">
          <img class="slide is-active" data-layer="0" src={firstSlide}
               alt="Historic restoration project by Eagle Restorations" />
          <img class="slide" data-layer="1" alt="" aria-hidden="true" />
          <span class="slide-cursor" aria-hidden="true">
            <span class="slide-cursor-pill">
              <span class="pill-flash"></span>
              <span class="pill-label">Next Image</span>
            </span>
          </span>
        </div>
      </div>
      <div class="about-copy">
        <h2 class="eyebrow">About Eagle Restorations</h2>
        <p class="lead">
          {company.name} specializes in the restoration and seismic repair and upgrading of
          historic buildings. Eagle was incorporated in 1991, and has completed over 80 projects,
          ranging in value up to 4.3 million dollars.
        </p>
        <p>
          Eagle emphasizes a high level of craft and restoration knowledge in all aspects of its
          work, and routinely works to the Secretary of the Interior's Standards for the Treatment
          of Historic Properties.
        </p>
        <p>
          Eagle is experienced in working under the auspices of different governmental agencies, and
          in meeting both the technical and administrative requirements of historic restoration work.
          Its core group of experienced restoration craftspeople are "hands-on" on every project.
        </p>
        <a href="/about-and-services/" class="link-gold">Read More &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-band">
    <div class="container stats-grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-num">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="section section-light">
    <div class="container">
      <h2 class="eyebrow">Our Services</h2>
      <div class="svc-grid">
        {services.map((svc) => (
          <article class="svc-card">
            <h3>{svc.title}</h3>
            <ul>
              {svc.items.map((i) => <li>{i}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section">
    <div class="container">
      <div class="feat-head">
        <h2 class="eyebrow">Featured Projects</h2>
        <a href="/projects/" class="link-gold">View All Projects &rarr;</a>
      </div>
      <div class="feat-grid">
        {featured.map((p) => (
          <a href={`/projects/${p.slug}/`} class="feat-card">
            {p.image
              ? <img src={localImage(p.image)} alt={p.title} loading="lazy" />
              : <div class="img-placeholder feat-ph"></div>}
            <span class="feat-overlay">
              <span class="feat-cat">{p.categories[0]}</span>
              <span class="feat-title">{p.title}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--hero-placeholder);
    position: relative;
    overflow: hidden;
    /* Fills the viewport — pushes the bottom of the section (and the
       bottom-anchored Unicorn Studio scene, see HeroCanvas.astro) as far
       down as the screen allows, exposing more of the scene's sky at the
       top, where the hero copy sits. 100svh (falls back to 100vh in
       browsers that don't support it) avoids the mobile-browser-chrome
       jump that plain 100vh causes; the 600px floor keeps short/landscape
       screens from squeezing the copy. */
    min-height: max(600px, 100vh);
    min-height: max(600px, 100svh);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 112px;
    padding-bottom: 120px;
  }
  .hero-kicker {
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink-soft);
    margin: 0 0 22px;
  }
  .hero-kicker .lic {
    display: block;
    color: var(--gold-dark);
    margin-top: 6px;
  }
  .hero h1 { margin: 0 0 22px; max-width: 18ch; }
  .hero-sub {
    font-size: 1.12rem;
    color: var(--ink-soft);
    max-width: 48ch;
    margin: 0 0 34px;
  }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; }

  @media (max-width: 768px) {
    .hero-content { padding-top: 64px; padding-bottom: 72px; }
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 56px;
    align-items: center;
  }
  .slideshow {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 0;
    overflow: hidden;
    cursor: pointer;
    background: var(--bg-light);
    box-shadow:
      0 1px 2px rgba(20, 18, 12, 0.08),
      0 5px 12px -4px rgba(20, 18, 12, 0.20),
      0 12px 20px -10px rgba(20, 18, 12, 0.16);
  }
  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.85s ease;
  }
  .slide.is-active { opacity: 1; }

  .slide-cursor {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    opacity: 0;
    z-index: 2;
    transition: opacity 0.2s ease;
    transform: translate(-9999px, -9999px);
  }
  .slide-cursor-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    overflow: hidden;
    background: var(--gold);
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 13px 24px;
    border-radius: 999px;
    box-shadow: 0 10px 22px -6px rgba(20, 18, 12, 0.4);
  }
  .pill-flash {
    position: absolute;
    inset: 0;
    background: var(--brand-dark);
    transform: scaleX(0);
    transform-origin: left;
  }
  .pill-label {
    position: relative;
    z-index: 1;
    color: var(--brand-dark);
  }
  .slideshow.has-cursor-pill { cursor: none; }
  .slideshow.has-cursor-pill .slide-cursor { opacity: 1; }

  @keyframes cursor-pill-bounce {
    0%   { transform: scale(1); }
    35%  { transform: scale(0.76); }
    65%  { transform: scale(1.14); }
    100% { transform: scale(1); }
  }
  .slide-cursor-pill.is-bouncing {
    animation: cursor-pill-bounce 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Black-to-yellow wipe: fills left-to-right, holds, then recedes left-to-right back to yellow */
  @keyframes pill-flash-wipe {
    0%   { transform: scaleX(0); transform-origin: left; }
    45%  { transform: scaleX(1); transform-origin: left; }
    55%  { transform: scaleX(1); transform-origin: right; }
    100% { transform: scaleX(0); transform-origin: right; }
  }
  @keyframes pill-label-flash {
    0%   { color: var(--brand-dark); }
    45%  { color: var(--gold); }
    55%  { color: var(--gold); }
    100% { color: var(--brand-dark); }
  }
  .slide-cursor-pill.is-flashing .pill-flash {
    animation: pill-flash-wipe 0.56s ease-in-out;
  }
  .slide-cursor-pill.is-flashing .pill-label {
    animation: pill-label-flash 0.56s ease-in-out;
  }

  @media (hover: none), (pointer: coarse) {
    .slide-cursor { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide-cursor-pill.is-bouncing { animation: none; }
    .slide-cursor-pill.is-flashing .pill-flash,
    .slide-cursor-pill.is-flashing .pill-label { animation: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
  }
  .lead { font-weight: 700; font-size: 1.18rem; color: var(--ink); }

  .stats-band { padding: 18px 0 64px; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .stat-num {
    font-family: var(--font-head);
    font-weight: 300;
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1;
    color: var(--ink);
  }
  .stat-label { color: var(--ink-soft); margin-top: 6px; }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .svc-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px 26px;
  }
  .svc-card h3 { margin-bottom: 16px; }
  .svc-card ul { margin: 0; padding-left: 18px; }
  .svc-card li { margin-bottom: 9px; color: var(--ink-soft); font-size: 0.96rem; }

  .feat-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
  }
  .feat-head .eyebrow { margin-bottom: 28px; }
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .feat-card {
    position: relative;
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }
  .feat-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .feat-ph { height: 100%; aspect-ratio: auto; }
  .feat-card:hover img { transform: scale(1.04); }
  .feat-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px;
    background: linear-gradient(to top, rgba(35,31,32,0.6) 0%, rgba(35,31,32,0) 55%);
    color: #fff;
  }
  .feat-cat {
    align-self: flex-start;
    display: inline-block;
    background: var(--gold);
    color: var(--brand-dark);
    font-family: var(--font-head);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    padding: 5px 10px;
    border-radius: 0;
    margin-bottom: 8px;
  }
  .feat-title { font-family: var(--font-head); font-weight: 600; font-size: 1.25rem; }

  @media (max-width: 940px) {
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .about-grid { grid-template-columns: 1fr; gap: 30px; }
    .stats-grid { grid-template-columns: 1fr; gap: 20px; text-align: center; }
    .svc-grid, .feat-grid { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ images: slideshowImages }}>
  // astro:page-load so this rewires the slideshow every time the homepage is
  // (re)displayed via a view-transition navigation, not just the true first
  // load — each firing gets its own fresh DOM refs since the page's markup
  // is freshly rendered each time.
  document.addEventListener('astro:page-load', function () {
    const box = document.getElementById('aboutSlideshow');
    if (!box || !Array.isArray(images) || images.length < 2) return;

    const layers = box.querySelectorAll('.slide');
    let active = box.querySelector('.slide.is-active') || layers[0];
    let hidden = layers[0] === active ? layers[1] : layers[0];
    let current = active.getAttribute('src');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const INTERVAL = 3000;
    let timer = null;
    let paused = false;

    function pickNext() {
      let next;
      do {
        next = images[Math.floor(Math.random() * images.length)];
      } while (next === current && images.length > 1);
      return next;
    }

    function advance() {
      const next = pickNext();
      const pre = new Image();
      const swap = function () {
        hidden.src = next;
        hidden.classList.add('is-active');
        active.classList.remove('is-active');
        const tmp = active; active = hidden; hidden = tmp;
        current = next;
      };
      pre.onload = swap;
      pre.onerror = swap;
      pre.src = next;
    }

    function start() { stop(); if (!paused) timer = setInterval(advance, INTERVAL); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    // Custom "Next Image" cursor pill (pointer devices only)
    const cursorPill = box.querySelector('.slide-cursor');
    const cursorPillInner = box.querySelector('.slide-cursor-pill');
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    function moveCursorPill(e) {
      const rect = box.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      cursorPill.style.transform = 'translate(' + x + 'px, ' + y + 'px) translate(-50%, -50%)';
    }

    function bounceCursorPill() {
      if (!cursorPillInner) return;
      cursorPillInner.classList.remove('is-bouncing', 'is-flashing');
      void cursorPillInner.offsetWidth; // force reflow so the animations can retrigger
      cursorPillInner.classList.add('is-bouncing', 'is-flashing');
    }
    if (cursorPillInner) {
      // Animation events bubble up from the .pill-flash / .pill-label children,
      // so remove each class only once its own animation actually finishes.
      cursorPillInner.addEventListener('animationend', function (e) {
        if (e.animationName === 'cursor-pill-bounce') {
          cursorPillInner.classList.remove('is-bouncing');
        } else if (e.animationName === 'pill-flash-wipe' || e.animationName === 'pill-label-flash') {
          cursorPillInner.classList.remove('is-flashing');
        }
      });
    }

    box.addEventListener('mouseenter', function (e) {
      paused = true;
      stop();
      if (cursorPill && canHover) {
        moveCursorPill(e);
        box.classList.add('has-cursor-pill');
      }
    });
    box.addEventListener('mouseleave', function () {
      paused = false;
      start();
      if (cursorPill) box.classList.remove('has-cursor-pill');
    });
    if (cursorPill && canHover) box.addEventListener('mousemove', moveCursorPill);
    box.addEventListener('click', function () {
      advance();
      start();
      if (canHover) bounceCursorPill();
    });

    if (!reduce) start();

    // Stop the interval before this page's content is swapped out by a view
    // transition, so a stale timer doesn't keep firing against detached
    // slideshow nodes in the background.
    document.addEventListener('astro:before-swap', function cleanup() {
      stop();
      document.removeEventListener('astro:before-swap', cleanup);
    }, { once: true });
  });
</script>

<script>
  // Registered once (module scripts aren't re-injected by view transitions),
  // but the listener itself persists on `document` and fires again on every
  // navigation back to the homepage, re-querying whatever .stat-num elements
  // that page currently has.
  document.addEventListener('astro:page-load', () => {
    const nums = document.querySelectorAll('.stat-num');
    if (nums.length) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (!en.isIntersecting) return;
          io.unobserve(en.target);
          const el = en.target;
          const m = el.textContent.trim().match(/^(\d[\d,]*)(\D*)$/);
          if (!m) return;
          const target = parseInt(m[1].replace(/,/g, ''), 10);
          const suffix = m[2] || '';
          if (reduce) { el.textContent = target.toLocaleString() + suffix; return; }
          const dur = 1500;
          const t0 = performance.now();
          function tick(now) {
            const p = Math.min((now - t0) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.round(eased * target).toLocaleString() + suffix;
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = target.toLocaleString() + suffix;
          }
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.5 });
      nums.forEach((n) => io.observe(n));
    }
  });
</script>
