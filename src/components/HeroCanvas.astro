---
// WebGL hero background — the actual scene, built in Unicorn Studio's
// no-code editor (https://unicorn.studio), not a hand-rolled shader.
// Embedded via Unicorn Studio's runtime SDK per their embed guide:
// https://www.unicorn.studio/docs/embed/
//
// Replaces .hero's flat --bg-light fill. Wired to Lenis smooth-scroll via
// UnicornStudio.setScroll() (see the lenis.on('scroll', …) call in
// Base.astro), so scroll-driven motion in the scene stays in sync with the
// site's virtual scroll instead of drifting from native window.scrollY.
// cacheBust: Unicorn Studio's CDN can take 1-2 min to pick up edits published
// in the editor (see "Caching Behavior" in their embed guide), and browsers
// cache the project JSON on top of that. Bump this string whenever a scene
// edit isn't showing up live to force a fresh fetch.
const { projectId = 'UtOrFoOSCxh53JBMPnH4', cacheBust = '3' } = Astro.props;
---
<div
  id="hero-unicorn"
  class="hero-unicorn"
  data-us-project={`${projectId}?update=${cacheBust}`}
  data-us-scale="1"
  data-us-dpi="1.5"
  data-us-lazyload="true"
  data-us-production="true"
  data-us-alttext="Decorative animated background"
  data-us-arialabel="Decorative animated background"
></div>

<style>
  /* Fills the hero panel exactly. (Previously oversized to 125% height to
     force a top-crop, but the scene appears to fit-to-contain within
     whatever box it's given rather than cover-crop it — the taller,
     more-portrait box was shrinking the scene down and leaving empty
     margins on the left/right. Matching the container 1:1 avoids that.) */
  .hero-unicorn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('hero-unicorn');
    if (!el) return;

    // Skip the scene under reduced motion — hero falls back to the plain
    // --bg-light background from .hero. Must run before UnicornStudio.init()
    // picks up the data-us-project attribute below.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.removeAttribute('data-us-project');
      return;
    }

    // Unicorn Studio's standard SDK loader snippet (embed guide, "Native"
    // path): load the runtime once, then init any data-us-project elements.
    var u = window.UnicornStudio;
    if (u && u.init) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () { u.init(); });
      } else {
        u.init();
      }
    } else {
      window.UnicornStudio = { isInitialized: false };
      var i = document.createElement('script');
      i.src = 'https://cdn.jsdelivr.net/gh/hiunicornstudio/unicornstudio.js@v2.2.6/dist/unicornStudio.umd.js';
      i.onload = function () {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () { window.UnicornStudio.init(); });
        } else {
          window.UnicornStudio.init();
        }
      };
      (document.head || document.body).appendChild(i);
    }
  })();
</script>
