{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Robots-Tag", "value": "noimageindex" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; img-src 'self' data: https://assets.unicorn.studio; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com; connect-src 'self' https://assets.unicorn.studio https://cdn.jsdelivr.net https://formspree.io https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com; worker-src 'self' blob:"
        }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|svg|avif)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, noimageindex" }
      ]
    }
  ],
  "redirects": [
    { "source": "/portfolio/:slug", "destination": "/projects/:slug", "permanent": true },
    { "source": "/portfolio", "destination": "/projects", "permanent": true },
    { "source": "/portfolio/", "destination": "/projects/", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home-page-2", "destination": "/", "permanent": true },
    { "source": "/about", "destination": "/about-and-services/", "permanent": true },
    { "source": "/services", "destination": "/about-and-services/", "permanent": true },
    { "source": "/press", "destination": "/press-awards/", "permanent": true },
    { "source": "/awards", "destination": "/press-awards/", "permanent": true },
    { "source": "/altadena", "destination": "/altadena-fire/", "permanent": true },
    { "source": "/wp-admin", "destination": "/", "permanent": false },
    { "source": "/wp-login.php", "destination": "/", "permanent": false }
  ]
}
