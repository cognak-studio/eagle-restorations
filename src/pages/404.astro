---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="nf">
    <div class="container">
      <p class="nf-code">404</p>
      <h1>This page couldn't be found</h1>
      <p class="nf-text">
        The page you're looking for may have moved or no longer exists. Let's get you back on track.
      </p>
      <div class="nf-actions">
        <a href="/" class="btn">Back to Home</a>
        <a href="/projects/" class="btn btn-outline">View Projects</a>
        <a href="/contact/" class="link-gold nf-contact">Contact Us &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    background: var(--bg-light);
    padding: 110px 0 120px;
    text-align: center;
  }
  .nf-code {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: clamp(5rem, 16vw, 10rem);
    line-height: 1;
    color: var(--gold);
    margin: 0;
  }
  .nf h1 { margin: 6px 0 14px; }
  .nf-text { max-width: 46ch; margin: 0 auto 30px; color: var(--ink-soft); font-size: 1.1rem; }
  .nf-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .nf-contact { margin-left: 4px; }
</style>
