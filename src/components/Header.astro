---
import { nav, announcement, company } from '../data/site.js';
const path = Astro.url.pathname;
---
<div class="announce">
  <a href={announcement.href}>{announcement.text} &rarr;</a>
</div>

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={company.name}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="40" height="40">
          <path fill="var(--gold)" d="M24 6c7 3 13 4 18 4-2 14-9 24-18 32C15 34 8 24 6 10c5 0 11-1 18-4z"/>
          <path fill="#fff" opacity="0.25" d="M24 6c7 3 13 4 18 4-2 14-9 24-18 32V6z"/>
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">EAGLE</span>
        <span class="brand-sub">Restorations Group, Inc.</span>
      </span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class={path.startsWith(item.href) && item.href !== '/' ? 'active' : ''}
        >{item.label}</a>
      ))}
    </nav>

    <a href="/contact/" class="btn quote-btn">Get a Quote</a>

    <button class="nav-toggle" aria-label="Menu" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/contact/" class="btn">Get a Quote</a>
  </div>
</header>

<style>
  .announce {
    background: var(--footer);
    color: #fff;
    text-align: center;
    font-size: 0.92rem;
    padding: 9px 16px;
  }
  .announce a { color: #fff; }
  .announce a:hover { color: var(--gold); text-decoration: none; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    min-height: 86px;
  }
  .brand { display: flex; align-items: center; gap: 12px; }
  .brand:hover { text-decoration: none; }
  .brand-mark { display: flex; }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.9rem;
    letter-spacing: 0.28em;
    color: var(--ink);
  }
  .brand-sub {
    font-family: var(--font-head);
    font-size: 0.56rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-top: 3px;
  }

  .main-nav {
    margin-left: auto;
    display: flex;
    gap: 30px;
  }
  .main-nav a {
    font-family: var(--font-head);
    font-weight: 500;
    color: var(--ink);
    font-size: 1.02rem;
  }
  .main-nav a:hover, .main-nav a.active { color: var(--gold-dark); text-decoration: none; }

  .quote-btn { flex: none; }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }
  .nav-toggle span {
    width: 26px; height: 2px; background: var(--ink); display: block;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 12px 24px 22px;
    border-top: 1px solid var(--line);
  }
  .mobile-nav a {
    font-family: var(--font-head);
    color: var(--ink);
    padding: 10px 0;
    font-size: 1.05rem;
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav .btn { width: max-content; margin-top: 8px; }

  @media (max-width: 940px) {
    .main-nav, .quote-btn { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const t = document.getElementById('navToggle');
  const m = document.getElementById('mobileNav');
  t?.addEventListener('click', () => m?.classList.toggle('open'));
</script>
