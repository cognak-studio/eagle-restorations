---
import { nav, announcement, company } from '../data/site.js';
const path = Astro.url.pathname;
---
<div class="announce">
  <a href={announcement.href}>{announcement.text} &rarr;</a>
</div>

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={company.name}>
      <img src="/eagle-restorations-logo.svg" alt={company.name} class="brand-logo" width="552" height="158" />
    </a>

    <nav class="main-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          data-label={item.label}
          class={path.startsWith(item.href) && item.href !== '/' ? 'active' : ''}
        ><span class="nav-label">{item.label}</span></a>
      ))}
    </nav>

    <a href="/contact/" class="btn quote-btn">Plan Your Restoration</a>

    <button class="nav-toggle" aria-label="Menu" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/contact/" class="btn">Plan Your Restoration</a>
  </div>
</header>

<style>
  .announce {
    background: var(--footer);
    color: #fff;
    text-align: center;
    font-size: 0.92rem;
    padding: 9px 16px;
  }
  .announce a { color: #fff; }
  .announce a:hover { color: var(--gold); text-decoration: none; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 24px;
    min-height: 86px;
  }
  .brand { display: flex; align-items: center; }
  .brand:hover { text-decoration: none; }
  .brand-logo { height: 46px; width: auto; display: block; }
  @media (max-width: 480px) { .brand-logo { height: 38px; } }

  .main-nav {
    margin-left: auto;
    display: flex;
    gap: 30px;
  }
  .main-nav a {
    display: inline-grid;
    font-family: var(--font-head);
    font-weight: 500;
    color: var(--ink);
    font-size: 0.9rem;
  }
  .main-nav a .nav-label { grid-area: 1 / 1; }
  /* hidden bold ghost reserves width so hover-bolding doesn't shift siblings */
  .main-nav a::after {
    content: attr(data-label);
    grid-area: 1 / 1;
    font-weight: 700;
    visibility: hidden;
  }
  .main-nav a:hover { color: var(--gold-dark); text-decoration: none; }
  .main-nav a.active { color: var(--gold-dark); text-decoration: none; }
  .main-nav a:hover .nav-label,
  .main-nav a.active .nav-label { font-weight: 700; }

  .quote-btn { flex: none; }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }
  .nav-toggle span {
    width: 26px; height: 2px; background: var(--ink); display: block;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 12px 24px 22px;
    border-top: 1px solid var(--line);
  }
  .mobile-nav a {
    font-family: var(--font-head);
    color: var(--ink);
    padding: 10px 0;
    font-size: 1.05rem;
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav .btn { width: max-content; margin-top: 8px; }

  @media (max-width: 940px) {
    .main-nav, .quote-btn { display: none; }
    .nav-toggle { display: flex; }
  }
</style>

<script>
  const t = document.getElementById('navToggle');
  const m = document.getElementById('mobileNav');
  t?.addEventListener('click', () => m?.classList.toggle('open'));
</script>
