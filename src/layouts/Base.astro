---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company, services, founder } from '../data/site.js';

const { title, description } = Astro.props;
const fullTitle = title ? `${title} | ${company.name}` : company.name;
const desc = description || `${company.shortName} specializes in the restoration and seismic repair of historic buildings throughout California.`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.jpg', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;
const orgId = `${siteUrl}#organization`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  '@id': orgId,
  name: company.name,
  legalName: company.name,
  alternateName: company.shortName,
  slogan: company.tagline,
  url: siteUrl,
  email: company.email,
  telephone: company.phone,
  image: ogImage,
  logo: `${siteUrl}eagle-restorations-logo.svg`,
  description: desc,
  priceRange: '$$$$',
  foundingDate: '1991',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '5441 Cogswell Rd Suite A',
    addressLocality: 'Arcadia',
    addressRegion: 'CA',
    postalCode: '91006',
    addressCountry: 'US',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    telephone: company.phone,
    email: company.email,
    areaServed: 'US-CA',
    availableLanguage: ['en'],
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: { '@type': 'State', name: 'California' },
  knowsAbout: [
    'Historic Restoration',
    'Seismic Retrofit',
    'Unreinforced Masonry (URM) Retrofit',
    'Adobe Restoration',
    'Structural Repair',
    'Fire Restoration',
    "Secretary of the Interior's Standards for the Treatment of Historic Properties",
    'Historic Tax Credit Certification',
    'National Register of Historic Places Restoration',
  ],
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'license',
    name: "Class 'B' General Building Contractor License",
    identifier: '465977',
    recognizedBy: {
      '@type': 'GovernmentOrganization',
      name: 'California State License Board (CSLB)',
    },
  },
  memberOf: {
    '@type': 'Organization',
    name: 'California Preservation Foundation',
  },
  founder: {
    '@type': 'Person',
    name: founder.name,
    jobTitle: founder.jobTitle,
    memberOf: founder.memberOf.map((name) => ({ '@type': 'Organization', name })),
  },
  award: [
    'Recognized by the California Preservation Foundation',
    'Recognized by the Governor of the State of California',
    'Recognized by the Getty Conservation Institute',
    'Recognized by the City of San Diego',
  ],
  review: {
    '@type': 'Review',
    reviewBody:
      "We highly recommend Eagle Restorations. Due to their extensive experience with historic masonry buildings, they approach a project with the appropriate sensitivity and propose solutions to situations as they arise during construction. They demonstrate attention to detail and pride in their work.",
    author: {
      '@type': 'Person',
      name: 'Ann E. Huston',
      jobTitle: "Contracting Officer's Representative, National Park Service at Channel Islands National Park",
    },
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Restoration & Structural Services',
    itemListElement: services.map((svc) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: svc.title,
        description: svc.items.join('; '),
        areaServed: { '@type': 'State', name: 'California' },
      },
    })),
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Years in Business', value: '36' },
    { '@type': 'PropertyValue', name: 'Projects Completed', value: '80+' },
    { '@type': 'PropertyValue', name: 'Maximum Project Value', value: '$4,300,000' },
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={company.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var sel = [
          '.hero-kicker', '.hero h1', '.hero-sub', '.hero-cta',
          '.page-head h1', '.page-head p',
          'main .eyebrow', 'main .lead',
          '.about-media', '.about-copy p', '.about-copy .link-gold',
          '.intro-media', '.intro-copy p', '.dir-media',
          '.stat', '.svc-card', '.feat-head', '.feat-card', '.proj-card',
          '.contact-info .info-item', '.contact-form',
          '.ft-cta-text', '.ft-col'
        ].join(',');
        var els = Array.prototype.slice.call(document.querySelectorAll(sel));
        if (!els.length) return;
        document.documentElement.classList.add('reveal-ready');

        var groups = new Map();
        els.forEach(function (el) {
          el.setAttribute('data-reveal', '');
          var p = el.parentElement;
          var arr = groups.get(p) || [];
          arr.push(el);
          groups.set(p, arr);
        });
        groups.forEach(function (arr) {
          arr.forEach(function (el, i) {
            el.style.transitionDelay = Math.min(i * 70, 420) + 'ms';
          });
        });

        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              io.unobserve(e.target);
              e.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>

    <script>
      import Lenis from 'lenis';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        // Exposed so other scripts (e.g. the homepage hero canvas) can read
        // live scroll position without instantiating their own Lenis.
        (window as any).lenis = lenis;

        // Keep the Unicorn Studio hero scene's scroll-driven motion in sync
        // with Lenis's virtual scroll (native window.scrollY doesn't move
        // with Lenis's transform-based smoothing). Per Unicorn Studio's docs:
        // https://www.unicorn.studio/docs/embed/#virtual-scroll
        lenis.on('scroll', ({ scroll }: { scroll: number }) => {
          const us = (window as any).UnicornStudio;
          if (us && typeof us.setScroll === 'function') us.setScroll(scroll);
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Smoothly handle in-page anchor links
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (!id || id === '#') return;
            const target = document.querySelector(id);
            if (target) {
              e.preventDefault();
              lenis.scrollTo(target as HTMLElement, { offset: -90 });
            }
          });
        });
      }
    </script>
  </body>
</html>
